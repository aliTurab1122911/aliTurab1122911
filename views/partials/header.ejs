<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Maison Minimal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">Maison Minimal</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navmenu">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navmenu">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/products">Shop</a></li>
        <% if (currentUser && currentUser.role === 'admin') { %>
          <li class="nav-item"><a class="nav-link" href="/admin">Admin</a></li>
        <% } %>
      </ul>
      <form class="d-flex me-3" method="GET" action="/products">
        <input class="form-control form-control-sm" name="q" placeholder="Search" />
      </form>
      <a href="/cart" class="btn btn-outline-dark btn-sm me-2">Cart (<%= cartCount %>)</a>
      <% if (currentUser) { %>
        <% if (currentUser.role !== 'admin') { %><a href="/account/orders" class="btn btn-light btn-sm me-2">My Orders</a><% } %>
        <form method="POST" action="/logout" class="d-inline">
          <button class="btn btn-dark btn-sm">Logout</button>
        </form>
      <% } else { %>
        <a href="/login" class="btn btn-dark btn-sm">Login</a>
      <% } %>
    </div>
  </div>
</nav>
<main>
