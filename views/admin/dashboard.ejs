<%- include('../partials/header') %>
<section class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">Admin Dashboard</h1>
    <a href="/admin/products" class="btn btn-dark">Manage Products</a>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-md-4"><div class="card p-3"><p class="small text-muted mb-1">Total Orders</p><p class="h4"><%= sales.total_orders %></p></div></div>
    <div class="col-md-4"><div class="card p-3"><p class="small text-muted mb-1">Total Sales</p><p class="h4">$<%= Number(sales.total_sales).toFixed(2) %></p></div></div>
    <div class="col-md-4"><div class="card p-3"><p class="small text-muted mb-1">Low Stock Variants</p><p class="h4"><%= lowStock.low_stock_items %></p></div></div>
  </div>
  <h2 class="h5">Latest Orders</h2>
  <div class="table-responsive">
    <table class="table">
      <thead><tr><th>ID</th><th>Customer</th><th>Status</th><th>Total</th></tr></thead>
      <tbody>
      <% latestOrders.forEach((order) => { %>
        <tr><td>#<%= order.id %></td><td><%= order.customer_name %></td><td class="text-capitalize"><%= order.status %></td><td>$<%= Number(order.total_amount).toFixed(2) %></td></tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>
<%- include('../partials/footer') %>
