<%- include('../partials/header') %>
<section class="container py-5">
  <h1 class="h2 mb-4">Your Cart</h1>
  <% if (!cart.length) { %>
    <p>Your cart is empty. <a href="/products">Start shopping</a>.</p>
  <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle">
        <thead>
          <tr><th>Item</th><th>Size</th><th>Price</th><th>Qty</th><th></th></tr>
        </thead>
        <tbody>
          <% cart.forEach((item) => { %>
            <tr>
              <td><%= item.name %></td>
              <td><%= item.size %></td>
              <td>$<%= Number(item.price).toFixed(2) %></td>
              <td>
                <form method="POST" action="/cart/update" class="d-flex gap-2">
                  <input type="hidden" name="variantId" value="<%= item.variantId %>">
                  <input type="number" min="1" name="quantity" value="<%= item.quantity %>" class="form-control form-control-sm" style="max-width:90px;">
                  <button class="btn btn-outline-dark btn-sm">Update</button>
                </form>
              </td>
              <td>
                <form method="POST" action="/cart/remove/<%= item.variantId %>">
                  <button class="btn btn-sm btn-outline-danger">Remove</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="text-end">
      <p class="h5 mb-3">Subtotal: $<%= Number(total).toFixed(2) %></p>
      <a href="/checkout" class="btn btn-dark btn-lg">Proceed to Checkout</a>
    </div>
  <% } %>
</section>
<%- include('../partials/footer') %>
