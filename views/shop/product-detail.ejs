<%- include('../partials/header') %>
<section class="container py-5">
  <div class="row g-5">
    <div class="col-md-6">
      <img src="<%= images[0] ? images[0].image_url : 'https://via.placeholder.com/600x800?text=No+Image' %>" class="img-fluid rounded" alt="<%= product.name %>">
    </div>
    <div class="col-md-6">
      <p class="small text-muted"><%= product.category_name || 'Collection' %></p>
      <h1 class="h2"><%= product.name %></h1>
      <p class="h4 mb-4">$<%= Number(product.price).toFixed(2) %></p>
      <p class="text-muted"><%= product.description %></p>

      <form method="POST" action="/cart/add" class="mt-4">
        <input type="hidden" name="productId" value="<%= product.id %>">
        <div class="mb-3">
          <label class="form-label">Size</label>
          <select class="form-select" name="variantId" required>
            <% variants.forEach((variant) => { %>
              <option value="<%= variant.id %>" <%= variant.stock <= 0 ? 'disabled' : '' %>>
                <%= variant.size %> <%= variant.stock <= 0 ? '(Out of stock)' : '' %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Quantity</label>
          <input class="form-control" type="number" name="quantity" min="1" value="1">
        </div>
        <button class="btn btn-dark btn-lg">Add to Cart</button>
      </form>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
